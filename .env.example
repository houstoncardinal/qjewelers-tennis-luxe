SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_PROJECT_ID=""

# Admin dashboard login password (set your own).
ADMIN_TOKEN=""
# Signs the admin HttpOnly session cookie — any long random string, unique per environment.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=""

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Sign up at resend.com, verify your sending domain, then paste your API key:
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# ── Payments — Stripe (cards) ───────────────────────────────────────────────────
# Leave blank to ship without card payments — checkout gracefully hides this
# method (and falls back to PayPal, or a "being configured" message) when unset.
# Get test-mode keys from dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
VITE_STRIPE_PUBLISHABLE_KEY=""
# Created when you add a webhook endpoint pointing at
# https://yourdomain.com/.netlify/functions/stripe-webhook (dashboard.stripe.com/test/webhooks)
STRIPE_WEBHOOK_SECRET=""

# ── Payments — PayPal ────────────────────────────────────────────────────────────
# Leave blank to ship without PayPal — same graceful-degradation behavior as Stripe.
# Get sandbox keys from developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=""
VITE_PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# "sandbox" (default) or "live"
PAYPAL_MODE="sandbox"
# Created when you add a webhook pointing at
# https://yourdomain.com/.netlify/functions/paypal-webhook (same PayPal dashboard)
PAYPAL_WEBHOOK_ID=""

# ── Site URL (used for absolute OG image URLs and email links) ─────────────────
VITE_SITE_URL=""

# ── Analytics ─────────────────────────────────────────────────────────────────
VITE_GA4_ID=""
VITE_META_PIXEL_ID=""
VITE_TIKTOK_PIXEL_ID=""
